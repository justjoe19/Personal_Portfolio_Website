---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar';
import Hero from '../components/Hero';
import About from '../components/About'; 
import ServiceCard from '../components/ServiceCard';
import ProjectCarousel from '../components/ProjectCarousel';
import Contact from '../components/Contact';
import Footer from '../components/Footer';

// Service data focused on local business needs
const services = [
  { 
    id: "01", 
    title: "Search-Optimized Engineering", 
    description: "I don't just build websites; I engineer digital assets for the Google algorithm. By integrating technical SEO into the core architecture, I ensure your business outranks the competition and captures high-intent local traffic.",
    icon: "monitor"
  },
  { 
    id: "02", 
    title: "Core Web Vitals Performance", 
    description: "Speed is a ranking factor. I eliminate bounce rates by building sub-second experiences that pass every Core Web Vital test, ensuring your customers never wait and your search rankings never slip.",
    icon: "zap"
  },
  { 
    id: "03", 
    title: "Conversion-Driven SEO", 
    description: "Visibility is useless without conversion. I engineer SEO strategies that target high-intent customers in the South Bend and Elkhart regions, ensuring that the traffic your site receives actually leads to phone calls and sales.",
    icon: "settings"
  }
];

// Note: Icons are handled differently in React components, 
// I'll check ServiceCard to see how it uses them.

const projects = [
  {
    id: "p1",
    name: "TriStorm Restoration",
    tech: "Performance SEO / Responsive Architecture",
    desc: "A specialized service platform engineered to capture high-intent local restoration traffic. Features a streamlined conversion path for emergency inquiries and high-resolution asset management to showcase professional project outcomes.",
    image: "/assets/tristorm.webp", 
    link: "https://tristormrestoration.com" 
  },
  {
    id: "p2",
    name: "Ironpipe Plumbing",
    tech: "Local SEO / Conversion Optimization",
    desc: "A mobile-first platform engineered for a local plumbing enterprise. Designed for rapid emergency service inquiries with a custom lead-capture flow that streamlines customer intake and dispatch in the Michiana area.",
    image: "/assets/ironpipe.webp", 
    link: "https://justjoe19.github.io/IronPipe/" 
  },
  {
    id: "p3",
    name: "Haven",
    tech: "Asset Optimization / Search Visibility",
    desc: "A high-performance portfolio site optimized for high-resolution architectural assets. Engineered for maximum search visibility and seamless image delivery to ensure a luxury experience on any device.",
    image: "/assets/haven.webp",
    link: "https://justjoe19.github.io/haven/" 
  }
];
---

<Layout title="Michiana.dev | Precision Web Development & Software Engineering" isHome={true}>
	<div class="min-h-screen bg-brand-bg text-brand-text relative">
		{/* Global Background Depth */}
		<div class="fixed inset-0 bg-grid-pattern opacity-[0.03] pointer-events-none z-0"></div>
		
		<a href="#main-content" class="absolute -top-[100px] left-0 bg-brand-blue text-brand-bg p-4 z-[10000] font-bold transition-[top] duration-300 focus:top-0">Skip to main content</a>
		
		<Navbar client:load />
		
		<main id="main-content" class="pt-5 relative z-10">
			<Hero client:visible />

			<section id="portfolio" class="py-16 max-w-[1200px] mx-auto px-6">
				<div class="flex items-center gap-3 mb-16">
					<span class="h-[1px] w-[35px] bg-brand-blue"></span>
					<h2 class="text-2xl font-bold text-white">Recent Projects</h2>
				</div>
				<ProjectCarousel projects={projects} client:load />
			</section>

			<section id="services" class="py-16 max-w-[1200px] mx-auto px-6">
				<div class="flex items-center gap-3 mb-16">
					<span class="h-[1px] w-[35px] bg-brand-blue"></span>
					<h2 class="text-2xl font-bold text-white">Services</h2>
				</div>
				<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-12">
					{services.map(service => (
						<ServiceCard 
							id={service.id}
							title={service.title}
							description={service.description}
              iconType={service.icon}
						/>
					))}
				</div>

				<div class="flex justify-center">
					<a 
						href="#contact" 
						class="group relative w-full max-w-[260px] sm:w-[260px] flex items-center justify-center bg-brand-blue text-brand-bg py-4 rounded-lg font-bold text-base transition-all duration-300 hover:scale-105 active:scale-95 shadow-[0_0_20px_rgba(121,192,255,0.2)] hover:shadow-[0_0_25px_rgba(121,192,255,0.4)] overflow-hidden"
					>
						<span class="relative z-10">Schedule a Call</span>
						<div class="absolute inset-0 bg-white/20 translate-y-full transition-transform group-hover:translate-y-0"></div>
					</a>
				</div>
			</section>

      <section id="why-engineering" class="py-16 bg-brand-card/30 border-y border-brand-border/50">
        <div class="max-w-[1200px] mx-auto px-6">
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
            <div>
              <div class="flex items-center gap-3 mb-6">
                <span class="h-[1px] w-[35px] bg-brand-green"></span>
                <span class="text-brand-green font-mono text-sm tracking-widest uppercase">The Competitive Edge</span>
              </div>
              <h2 class="text-4xl font-bold text-white mb-6 leading-tight tracking-tight">Web Engineering <br/><span class="text-brand-blue">vs. Agency Templates</span></h2>
              <p class="text-brand-dim text-lg mb-8 max-w-xl font-medium">
                Most local agencies sell bloated, slow templates that frustrate users and get buried by Google. I engineer high-performance digital assets from the ground up.
              </p>
              
              <div class="space-y-6">
                <div class="flex gap-4">
                  <div class="flex-shrink-0 w-12 h-12 rounded-lg bg-brand-blue/10 flex items-center justify-center border border-brand-blue/20">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-brand-blue" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 14 4-4"/><path d="M3.34 19a10 10 0 1 1 17.32 0"/></svg>
                  </div>
                  <div>
                    <h3 class="text-white font-bold mb-1">SEO Dominance</h3>
                    <p class="text-brand-dim text-sm font-medium">Google's "Core Web Vitals" algorithm favors speed. My 100/100 performance scores ensure you outrank the competition.</p>
                  </div>
                </div>
                <div class="flex gap-4">
                  <div class="flex-shrink-0 w-12 h-12 rounded-lg bg-brand-green/10 flex items-center justify-center border border-brand-green/20">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-brand-green" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                  </div>
                  <div>
                    <h3 class="text-white font-bold mb-1">Unmatched Security</h3>
                    <p class="text-brand-dim text-sm font-medium">By using a headless architecture (Astro + React), I eliminate the vulnerabilities inherent in WordPress and other common platforms.</p>
                  </div>
                </div>
              </div>
            </div>

            <div class="relative">
              <div class="glass-card p-8 rounded-2xl border border-white/10 relative z-10 shadow-2xl">
                <div class="flex justify-between items-center mb-8">
                  <span class="font-mono text-xs text-brand-dim tracking-widest uppercase opacity-70">Project_Audit.log</span>
                  <div class="flex gap-1.5">
                    <div class="w-2.5 h-2.5 rounded-full bg-red-500/30 border border-red-500/50"></div>
                    <div class="w-2.5 h-2.5 rounded-full bg-yellow-500/30 border border-yellow-500/50"></div>
                    <div class="w-2.5 h-2.5 rounded-full bg-brand-green/30 border border-brand-green/50"></div>
                  </div>
                </div>
                
                <div class="space-y-8">
                  <div>
                    <div class="flex justify-between text-sm mb-2">
                      <span class="text-brand-blue font-bold tracking-tight">Performance</span>
                      <span class="text-brand-green font-mono font-bold">100/100</span>
                    </div>
                    <div class="h-1.5 w-full bg-white/5 rounded-full overflow-hidden">
                      <div class="h-full bg-brand-green w-full shadow-[0_0_15px_rgba(126,231,135,0.4)]"></div>
                    </div>
                  </div>
                  <div>
                    <div class="flex justify-between text-sm mb-2">
                      <span class="text-brand-blue font-bold tracking-tight">Accessibility</span>
                      <span class="text-brand-green font-mono font-bold">100/100</span>
                    </div>
                    <div class="h-1.5 w-full bg-white/5 rounded-full overflow-hidden">
                      <div class="h-full bg-brand-green w-full shadow-[0_0_15px_rgba(126,231,135,0.4)]"></div>
                    </div>
                  </div>
                  <div>
                    <div class="flex justify-between text-sm mb-2">
                      <span class="text-brand-blue font-bold tracking-tight">Best Practices</span>
                      <span class="text-brand-green font-mono font-bold">100/100</span>
                    </div>
                    <div class="h-1.5 w-full bg-white/5 rounded-full overflow-hidden">
                      <div class="h-full bg-brand-green w-full shadow-[0_0_15px_rgba(126,231,135,0.4)]"></div>
                    </div>
                  </div>
                  <div>
                    <div class="flex justify-between text-sm mb-2">
                      <span class="text-brand-blue font-bold tracking-tight">SEO</span>
                      <span class="text-brand-green font-mono font-bold">100/100</span>
                    </div>
                    <div class="h-1.5 w-full bg-white/5 rounded-full overflow-hidden">
                      <div class="h-full bg-brand-green w-full shadow-[0_0_15px_rgba(126,231,135,0.4)]"></div>
                    </div>
                  </div>
                </div>

                <div class="mt-8 pt-8 border-t border-white/5 text-center">
                  <p class="text-[10px] font-mono text-brand-dim leading-relaxed uppercase tracking-[0.2em] opacity-60">
                    Verified Lighthouse Metrics
                  </p>
                </div>
              </div>
              
              {/* Decorative elements */}
              <div class="absolute -top-10 -right-10 w-40 h-40 bg-brand-blue/10 rounded-full blur-[80px] -z-10"></div>
              <div class="absolute -bottom-10 -left-10 w-40 h-40 bg-brand-green/10 rounded-full blur-[80px] -z-10"></div>
            </div>
          </div>
        </div>
      </section>

			<About />

			<Contact client:visible />
		</main>

		<Footer />
	</div>
</Layout>
