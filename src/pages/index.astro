---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar';
import Hero from '../components/Hero';
import About from '../components/About';
import ServiceCard from '../components/ServiceCard';
import ProjectCarousel from '../components/ProjectCarousel';
import Contact from '../components/Contact';
import Footer from '../components/Footer';

const serviceAreas = ["South Bend, IN", "Mishawaka, IN", "Elkhart, IN", "Granger, IN", "Goshen, IN", "Niles, MI"];

const faqs = [
  {
    q: "How much does a custom website or software project cost for a South Bend or Mishawaka business?",
    a: "Every project is scoped individually based on your specific requirements and goals. I offer a free consultation to provide a clear, no-obligation estimate. My rates reflect the value of purpose-built software — not the overhead of larger agencies using generic templates."
  },
  {
    q: "What is the difference between a web developer and a software engineer?",
    a: "A web developer typically builds sites using pre-made templates and page builders. A software engineer writes custom code from the ground up — optimized specifically for your performance, security, and business requirements. The result is a faster, more secure, and more scalable digital product with no unnecessary overhead."
  },
  {
    q: "Do you work with businesses outside the Michiana area?",
    a: "Yes. While I'm based in Mishawaka, IN, and specialize in the local South Bend, Elkhart, and Michiana markets, I work with clients nationwide for software engineering, SaaS development, and web application projects."
  },
  {
    q: "How long does it take to build a custom website?",
    a: "Timelines vary by project scope — I've delivered custom websites in as little as two weeks. SaaS applications and more complex software projects are scoped individually with a clear timeline established upfront. You'll always know what to expect and when."
  },
  {
    q: "What is local SEO and why does my Michiana business need it?",
    a: "Local SEO is the practice of optimizing your online presence so your business appears at the top of Google when customers in your area search for your services. For businesses in South Bend, Mishawaka, and Elkhart, strong local SEO is often the most cost-effective marketing available — and it starts with a technically sound, fast-loading website."
  }
];

const faqSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(faq => ({
    "@type": "Question",
    "name": faq.q,
    "acceptedAnswer": { "@type": "Answer", "text": faq.a }
  }))
});

const services = [
  {
    id: "01",
    title: "Custom Software & SaaS Development",
    description: "I build full-stack web applications and SaaS platforms from the ground up — custom tools, internal dashboards, and client-facing products engineered for performance, scalability, and clean architecture.",
    icon: "code"
  },
  {
    id: "02",
    title: "High-Performance Web Engineering",
    description: "Every site I deliver is custom-built for speed. No bloated templates, no plugins — just clean, efficient code that scores 100/100 on Core Web Vitals and keeps your users engaged from the first byte.",
    icon: "zap"
  },
  {
    id: "03",
    title: "Local SEO & Search Strategy",
    description: "Technical SEO is engineered into the architecture of every project — not bolted on after the fact. For Michiana businesses and clients nationwide, this means higher rankings, qualified traffic, and real conversions.",
    icon: "settings"
  },
  {
    id: "04",
    title: "AI & Automation Integration",
    description: "I integrate AI tools and automation workflows directly into your business operations — from custom LLM-powered features to process automation that eliminates manual work and scales your team's output.",
    icon: "cpu"
  }
];

const projects = [
  {
    id: "p1",
    name: "TriStorm Restoration",
    tech: "Performance SEO / Responsive Architecture",
    desc: "A specialized service platform engineered to capture high-intent local restoration traffic. Features a streamlined conversion path for emergency inquiries and high-resolution asset management to showcase professional project outcomes.",
    image: "/assets/tristorm.webp", 
    link: "https://tristormrestoration.com" 
  },
  {
    id: "p2",
    name: "HSC Portal",
    tech: "Full-Stack Architecture / Secure Role-Based Access",
    desc: "A full-stack healthcare appointment management platform built with Java Spring Boot and React. Features stateless JWT authentication, role-based portals for patients, doctors, and administrators, and a fully responsive interface engineered for secure, reliable scheduling.",
    image: "/assets/HSC-Portal.webp",
    link: "https://github.com/justjoe19/HSC_Portal"
  },
  {
    id: "p3",
    name: "Haven",
    tech: "Asset Optimization / Search Visibility",
    desc: "A high-performance portfolio site optimized for high-resolution architectural assets. Engineered for maximum search visibility and seamless image delivery to ensure a luxury experience on any device.",
    image: "/assets/haven.webp",
    link: "https://justjoe19.github.io/haven/" 
  }
];
---

<Layout title="Software Engineer & Web Developer — Mishawaka, IN | Michiana.dev" isHome={true}>
	<script type="application/ld+json" is:inline set:html={faqSchema} />
	<div class="min-h-screen bg-brand-bg text-brand-text relative">
		{/* Global Background Depth */}
		<div class="fixed inset-0 bg-grid-pattern opacity-[0.03] pointer-events-none z-0"></div>
		
		<a href="#main-content" class="absolute -top-[100px] left-0 bg-brand-blue text-brand-bg p-4 z-[10000] font-bold transition-[top] duration-300 focus:top-0">Skip to main content</a>
		
		<Navbar client:load />
		
		<main id="main-content" class="pt-5 relative z-10">
			<Hero client:visible />

			<section id="services" class="py-16 max-w-[1200px] mx-auto px-6">
				<div class="flex items-center gap-3 mb-16">
					<span class="h-[1px] w-[35px] bg-brand-blue"></span>
					<h2 class="text-2xl font-bold text-white">Services</h2>
				</div>
				<div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-12">
					{services.map(service => (
						<ServiceCard
							id={service.id}
							title={service.title}
							description={service.description}
              iconType={service.icon}
						/>
					))}
				</div>

				<div class="mt-16 pt-16 border-t border-brand-border/50 grid grid-cols-1 md:grid-cols-2 gap-16 items-center mb-16">
					<div>
						<div class="flex items-center gap-3 mb-6">
							<span class="h-[1px] w-[35px] bg-brand-blue"></span>
							<span class="text-brand-blue font-mono text-sm tracking-widest uppercase">The Competitive Edge</span>
						</div>
						<h2 class="text-4xl font-bold text-white mb-6 leading-tight tracking-tight">Custom Engineering <br/><span class="text-brand-blue">vs. Off-the-Shelf Solutions</span></h2>
						<p class="text-brand-dim text-lg mb-8 max-w-xl font-medium">
							Generic platforms and no-code tools have ceilings. When your business needs software that actually fits — fast, secure, and built to rank — engineering from scratch is the only answer.
						</p>
						<div class="space-y-6">
							<div class="flex gap-4">
								<div class="flex-shrink-0 w-12 h-12 rounded-lg bg-brand-blue/10 flex items-center justify-center border border-brand-blue/20">
									<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-brand-blue" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
								</div>
								<div>
									<h3 class="text-white font-bold mb-1">Purpose-Built Software</h3>
									<p class="text-brand-dim text-sm font-medium">Every application is built to your exact requirements — no plugin dependencies, no licensing fees, no feature ceilings.</p>
								</div>
							</div>
							<div class="flex gap-4">
								<div class="flex-shrink-0 w-12 h-12 rounded-lg bg-brand-green/10 flex items-center justify-center border border-brand-green/20">
									<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-brand-green" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
								</div>
								<div>
									<h3 class="text-white font-bold mb-1">Secure by Architecture</h3>
									<p class="text-brand-dim text-sm font-medium">Headless, decoupled builds eliminate the attack surface of WordPress and template platforms — no database, no vulnerabilities to patch.</p>
								</div>
							</div>
						</div>
					</div>
					<div class="relative">
						<div id="score-widget" class="glass-card p-8 rounded-2xl border border-white/10 relative z-10 shadow-2xl">
							<div class="flex justify-between items-center mb-8">
								<span class="font-mono text-xs text-brand-dim tracking-widest uppercase opacity-70">Project_Audit.log</span>
								<div class="flex gap-1.5">
									<div class="w-2.5 h-2.5 rounded-full bg-red-500/30 border border-red-500/50"></div>
									<div class="w-2.5 h-2.5 rounded-full bg-yellow-500/30 border border-yellow-500/50"></div>
									<div class="w-2.5 h-2.5 rounded-full bg-brand-green/30 border border-brand-green/50"></div>
								</div>
							</div>
							<div class="space-y-8">
								<div>
									<div class="flex justify-between text-sm mb-2">
										<span class="text-brand-blue font-bold tracking-tight">Performance</span>
										<span class="text-brand-green font-mono font-bold">100/100</span>
									</div>
									<div class="h-1.5 w-full bg-white/5 rounded-full overflow-hidden">
										<div data-bar class="h-full bg-brand-green shadow-[0_0_15px_rgba(126,231,135,0.4)]" style="width:0%;transition:width 1.1s cubic-bezier(0.4,0,0.2,1)"></div>
									</div>
								</div>
								<div>
									<div class="flex justify-between text-sm mb-2">
										<span class="text-brand-blue font-bold tracking-tight">Accessibility</span>
										<span class="text-brand-green font-mono font-bold">100/100</span>
									</div>
									<div class="h-1.5 w-full bg-white/5 rounded-full overflow-hidden">
										<div data-bar class="h-full bg-brand-green shadow-[0_0_15px_rgba(126,231,135,0.4)]" style="width:0%;transition:width 1.1s cubic-bezier(0.4,0,0.2,1)"></div>
									</div>
								</div>
								<div>
									<div class="flex justify-between text-sm mb-2">
										<span class="text-brand-blue font-bold tracking-tight">Best Practices</span>
										<span class="text-brand-green font-mono font-bold">100/100</span>
									</div>
									<div class="h-1.5 w-full bg-white/5 rounded-full overflow-hidden">
										<div data-bar class="h-full bg-brand-green shadow-[0_0_15px_rgba(126,231,135,0.4)]" style="width:0%;transition:width 1.1s cubic-bezier(0.4,0,0.2,1)"></div>
									</div>
								</div>
								<div>
									<div class="flex justify-between text-sm mb-2">
										<span class="text-brand-blue font-bold tracking-tight">SEO</span>
										<span class="text-brand-green font-mono font-bold">100/100</span>
									</div>
									<div class="h-1.5 w-full bg-white/5 rounded-full overflow-hidden">
										<div data-bar class="h-full bg-brand-green shadow-[0_0_15px_rgba(126,231,135,0.4)]" style="width:0%;transition:width 1.1s cubic-bezier(0.4,0,0.2,1)"></div>
									</div>
								</div>
							</div>
							<div class="mt-8 pt-8 border-t border-white/5 text-center">
								<p class="text-[10px] font-mono text-brand-dim leading-relaxed uppercase tracking-[0.2em] opacity-60">
									Verified Lighthouse Metrics
								</p>
							</div>
						</div>
						<div class="absolute -top-10 -right-10 w-40 h-40 bg-brand-blue/10 rounded-full blur-[80px] -z-10"></div>
						<div class="absolute -bottom-10 -left-10 w-40 h-40 bg-brand-green/10 rounded-full blur-[80px] -z-10"></div>
					</div>
				</div>

				<div class="flex justify-center">
					<a
						href="#contact"
						class="group relative w-full max-w-[260px] sm:w-[260px] flex items-center justify-center bg-brand-blue text-brand-bg py-4 rounded-lg font-bold text-base transition-all duration-300 hover:scale-105 active:scale-95 shadow-[0_0_20px_rgba(121,192,255,0.2)] hover:shadow-[0_0_25px_rgba(121,192,255,0.4)] overflow-hidden"
					>
						<span class="relative z-10">Schedule a Call</span>
						<div class="absolute inset-0 bg-white/20 translate-y-full transition-transform group-hover:translate-y-0"></div>
					</a>
				</div>
			</section>

			<section id="portfolio" class="py-16 max-w-[1200px] mx-auto px-6">
				<div class="flex items-center gap-3 mb-16">
					<span class="h-[1px] w-[35px] bg-brand-blue"></span>
					<h2 class="text-2xl font-bold text-white">Recent Projects</h2>
				</div>
				<ProjectCarousel projects={projects} client:load />
			</section>

			<section id="service-areas" class="py-16 max-w-[1200px] mx-auto px-6">
				<div class="flex items-center gap-3 mb-8">
					<span class="h-[1px] w-[35px] bg-brand-blue"></span>
					<h2 class="text-2xl font-bold text-white tracking-tight">Service Areas</h2>
				</div>
				<p class="text-brand-dim text-lg mb-8 max-w-2xl">
					Based in Mishawaka, IN — serving businesses across the Michiana region for web development, local SEO, and software engineering, with availability for SaaS and application projects nationwide.
				</p>
				<div class="flex flex-wrap gap-3">
					{serviceAreas.map(city => (
						<span class="inline-flex items-center gap-2 px-4 py-2 glass-card rounded-full text-sm font-semibold text-brand-text">
							<span class="w-1.5 h-1.5 rounded-full bg-brand-blue flex-shrink-0"></span>
							{city}
						</span>
					))}
					<span class="inline-flex items-center gap-2 px-4 py-2 rounded-full text-sm font-semibold text-brand-blue border border-brand-blue/30 bg-brand-blue/5">
						<span class="w-1.5 h-1.5 rounded-full bg-brand-blue flex-shrink-0"></span>
						Nationwide (Remote)
					</span>
				</div>
			</section>

			<About />

			<section id="faq" class="py-16 max-w-[1200px] mx-auto px-6">
				<div class="flex items-center gap-3 mb-10">
					<span class="h-[1px] w-[35px] bg-brand-blue"></span>
					<h2 class="text-2xl font-bold text-white tracking-tight">Frequently Asked Questions</h2>
				</div>
				<div class="space-y-3 max-w-[800px]">
					{faqs.map(faq => (
						<details class="group glass-card rounded-xl overflow-hidden">
							<summary class="flex justify-between items-center p-6 cursor-pointer list-none [&::-webkit-details-marker]:hidden text-white font-semibold hover:text-brand-blue transition-colors duration-200">
								{faq.q}
								<svg class="w-5 h-5 text-brand-blue flex-shrink-0 ml-4 transition-transform duration-300 group-open:rotate-180" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
									<path d="m6 9 6 6 6-6"/>
								</svg>
							</summary>
							<div class="px-6 pb-6 pt-4 text-brand-dim leading-relaxed border-t border-white/5">
								{faq.a}
							</div>
						</details>
					))}
				</div>
			</section>

			<Contact client:visible />
		</main>

		<Footer />
	</div>
</Layout>

<script>
  const widget = document.getElementById('score-widget');
  if (widget) {
    const bars = widget.querySelectorAll('[data-bar]');
    const observer = new IntersectionObserver(
      (entries) => {
        if (!entries[0].isIntersecting) return;
        observer.disconnect();
        bars.forEach((bar, i) => {
          setTimeout(() => { (bar as HTMLElement).style.width = '100%'; }, i * 200);
        });
      },
      { threshold: 0.5 }
    );
    observer.observe(widget);
  }
</script>
