---
import '../index.css';

interface Props {
	title: string;
	description?: string;
	image?: string;
	type?: 'website' | 'article';
	isHome?: boolean;
}

const { 
	title, 
	description = "Custom software engineering, SaaS development, and high-performance web solutions for businesses in Northern Indiana and nationwide.",
	image = "/assets/hero.webp",
	type = "website",
	isHome = false
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const socialImageURL = new URL(image, Astro.site);
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" type="image/x-icon" href="/favicon.ico" />
		<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
		<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
		<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
		<meta name="generator" content={Astro.generator} />
		
		<!-- Preloads: Only on Homepage for LCP optimization -->
		{isHome && (
			<link rel="preload" as="image" href="/assets/hero.webp" fetchpriority="high">
		)}
		
		<!-- Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link 
			rel="stylesheet" 
			href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,100..1000;1,9..40,100..1000&family=JetBrains+Mono:ital,wght@0,100..800;1,100..800&display=swap"
			media="print" 
			onload="this.media='all'"
		>
		<noscript>
			<link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,100..1000;1,9..40,100..1000&family=JetBrains+Mono:ital,wght@0,100..800;1,100..800&display=swap" rel="stylesheet">
		</noscript>

		<title>{title}</title>
		<meta name="description" content={description} />
		<meta name="keywords" content="Software Engineer Michiana, SaaS Developer Indiana, Custom Software Development South Bend, Full-Stack Developer Mishawaka, React Developer Indiana, Web Application Development Michiana, Local SEO South Bend, High-Performance Web Engineering" />
		<link rel="canonical" href={canonicalURL} />
		<meta name="theme-color" content="#0d1117" />

		<!-- Open Graph / Facebook -->
		<meta property="og:type" content={type} />
		<meta property="og:url" content={canonicalURL} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={socialImageURL} />

		<!-- Twitter -->
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:url" content={canonicalURL} />
		<meta property="twitter:title" content={title} />
		<meta property="twitter:description" content={description} />
		<meta property="twitter:image" content={socialImageURL} />

		<!-- Structured Data (JSON-LD): Only on Homepage -->
		{isHome && (
			<script type="application/ld+json" is:inline>
				{
					"@context": "https://schema.org",
					"@type": "WebSite",
					"name": "Michiana.dev",
					"url": "https://michiana.dev",
					"description": "Custom software engineering, SaaS development, and high-performance web solutions for businesses in Northern Indiana and nationwide."
				}
			</script>
		)}
		{isHome && (
			<script type="application/ld+json" is:inline>
				{
					"@context": "https://schema.org",
					"@type": "Person",
					"name": "Joe Hollenbach",
					"jobTitle": "Software Engineer",
					"url": "https://michiana.dev",
					"sameAs": [
						"https://www.linkedin.com/in/joe-hollenbach",
						"https://github.com/justjoe19"
					],
					"worksFor": {
						"@type": "Organization",
						"name": "Michiana.dev"
					},
					"address": {
						"@type": "PostalAddress",
						"addressLocality": "Mishawaka",
						"addressRegion": "IN",
						"addressCountry": "US"
					}
				}
			</script>
		)}
		{isHome && (
			<script type="application/ld+json" is:inline>
				{
					"@context": "https://schema.org",
					"@type": "ProfessionalService",
					"name": "Michiana.dev",
					"image": "https://michiana.dev/assets/hero.webp",
					"@id": "https://michiana.dev",
					"url": "https://michiana.dev",
					"telephone": "+15742138502",
					"sameAs": [
						"https://www.linkedin.com/in/joe-hollenbach",
						"https://github.com/justjoe19"
					],
					"address": {
						"@type": "PostalAddress",
						"streetAddress": "",
						"addressLocality": "Mishawaka",
						"addressRegion": "IN",
						"postalCode": "46544",
						"addressCountry": "US"
					},
					"geo": {
						"@type": "GeoCoordinates",
						"latitude": 41.6611,
						"longitude": -86.1706
					},
					"servesArea": [
						"South Bend, IN",
						"Mishawaka, IN",
						"Elkhart, IN",
						"Granger, IN",
						"Niles, MI"
					],
					"description": "Custom software engineering, SaaS development, and high-performance web solutions for Northern Indiana businesses and clients nationwide."
				}
			</script>
		)}

	</head>
	<body>
		<slot />
		<!-- Hidden form for Netlify field detection -->
		<form name="contact" data-netlify="true" hidden>
			<input type="hidden" name="form-name" value="contact" />
			<input type="text" name="name" />
			<input type="email" name="email" />
			<input type="tel" name="phone" />
			<textarea name="message"></textarea>
		</form>

		<script>
			import netlifyIdentity from 'netlify-identity-widget';

			// Initialize Netlify Identity
			netlifyIdentity.init();

			// Handle login and redirects
			netlifyIdentity.on('login', () => {
				document.location.href = "/admin/";
			});

			// If the URL has an invite or recovery token, force the widget to open
			if (window.location.hash.includes("invite_token") || window.location.hash.includes("recovery_token")) {
				netlifyIdentity.open();
			}

			// Make it available globally for the admin page if needed
			(window as any).netlifyIdentity = netlifyIdentity;
		</script>
	</body>
</html>
